<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" styleClass="module-root" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.java.com.model1.controller.BillHistoryController">
    <top>
        <VBox spacing="12.0" styleClass="module-header">
            <padding><Insets bottom="24.0" left="28.0" right="28.0" top="28.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="panel-kicker" text="Cashier / Bill History" />
                                <Label styleClass="dashboard-title" text="Bill History" />
                                <Label styleClass="dashboard-subtitle" text="Review saved bills, inspect line items, and trace generated receipt files." />
                            </children>
                        </VBox>
                        <Button onAction="#backToDashboard" styleClass="ghost-button" text="Dashboard" />
                        <Button onAction="#signOut" styleClass="sidebar-button" text="Sign out" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <VBox spacing="16.0">
            <padding><Insets bottom="28.0" left="28.0" right="28.0" top="28.0" /></padding>
            <children>
                <HBox spacing="12.0" styleClass="module-toolbar">
                    <children>
                        <TextField fx:id="dateField" promptText="Date, yyyy-MM-dd or MMddyyyy" styleClass="modern-input" HBox.hgrow="ALWAYS" />
                        <Button onAction="#loadHistoryForDate" styleClass="primary-button" text="Load date" />
                        <Button onAction="#loadAllHistory" styleClass="ghost-button" text="All bills" />
                    </children>
                </HBox>
                <TableView fx:id="billTable" prefHeight="300.0" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="90.0" text="Bill" />
                        <TableColumn fx:id="dateColumn" prefWidth="150.0" text="Date" />
                        <TableColumn fx:id="cashierColumn" prefWidth="180.0" text="Cashier" />
                        <TableColumn fx:id="itemsColumn" prefWidth="120.0" text="Items" />
                        <TableColumn fx:id="totalColumn" prefWidth="140.0" text="Total" />
                        <TableColumn fx:id="receiptColumn" prefWidth="260.0" text="Receipt file" />
                    </columns>
                </TableView>
                <Label styleClass="section-title" text="Selected Bill Items" />
                <TableView fx:id="itemTable" prefHeight="220.0" styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="productColumn" prefWidth="360.0" text="Product" />
                        <TableColumn fx:id="quantityColumn" prefWidth="120.0" text="Qty" />
                        <TableColumn fx:id="unitPriceColumn" prefWidth="160.0" text="Unit price" />
                        <TableColumn fx:id="lineTotalColumn" prefWidth="180.0" text="Line total" />
                        <TableColumn fx:id="sectorColumn" prefWidth="120.0" text="Sector" />
                    </columns>
                </TableView>
                <Label fx:id="statusLabel" minHeight="28.0" styleClass="status-line" wrapText="true" />
            </children>
        </VBox>
    </center>
</BorderPane>
